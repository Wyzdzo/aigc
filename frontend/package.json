{
  "name": "aigc-friendly-frontend",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . && npm run lint:colors && npm run lint:z-index",
    "lint:fix": "eslint . --fix && npm run lint:colors && npm run lint:z-index",
    "lint:colors": "node scripts/lint-colors.mjs",
    "lint:z-index": "node scripts/lint-z-index.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "check": "npm run format:check && npm run lint && npm run build",
    "security:audit": "npm audit --registry=https://registry.npmjs.org",
    "security:signatures": "npm audit signatures --registry=https://registry.npmjs.org",
    "security:check": "npm run security:audit && npm run security:signatures",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@ant-design/x": "^2.7.0",
    "@apollo/client": "^4.2.0",
    "@tiptap/extension-blockquote": "^3.26.1",
    "@tiptap/extension-bold": "^3.26.1",
    "@tiptap/extension-bullet-list": "^3.26.1",
    "@tiptap/extension-code": "^3.26.1",
    "@tiptap/extension-code-block": "^3.26.1",
    "@tiptap/extension-color": "^3.26.1",
    "@tiptap/extension-dropcursor": "^3.26.1",
    "@tiptap/extension-focus": "^3.26.1",
    "@tiptap/extension-gapcursor": "^3.26.1",
    "@tiptap/extension-heading": "^3.26.1",
    "@tiptap/extension-highlight": "^3.26.1",
    "@tiptap/extension-history": "^3.26.1",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-italic": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-list-item": "^3.26.1",
    "@tiptap/extension-ordered-list": "^3.26.1",
    "@tiptap/extension-paragraph": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/extension-strike": "^3.26.1",
    "@tiptap/extension-table": "^3.26.1",
    "@tiptap/extension-table-cell": "^3.26.1",
    "@tiptap/extension-table-header": "^3.26.1",
    "@tiptap/extension-table-row": "^3.26.1",
    "@tiptap/extension-task-item": "^3.26.1",
    "@tiptap/extension-task-list": "^3.26.1",
    "@tiptap/extension-text-style": "^3.26.1",
    "@tiptap/extension-underline": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "antd": "^6.4.3",
    "graphql": "^16.14.0",
    "highlight.js": "^11.11.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router": "^7.15.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
